# ============================================================================
# CONCEPT: Version Control (Week 14)
# ============================================================================
# This .gitignore file specifies files and directories that Git should NOT
# track. This is essential for:
#   - Keeping the repository clean (no compiled bytecode)
#   - Avoiding conflicts from IDE-specific settings
#   - Not committing sensitive or machine-specific data
#   - Reducing repository size
#
# Git Workflow for this project:
#   1. git init                          — Initialize repository
#   2. git add .                         — Stage all source files
#   3. git commit -m "Initial commit"    — Commit the initial codebase
#   4. Feature branches: git checkout -b feature/scan-worker
#   5. After development: git merge feature/scan-worker
#   6. Tag releases: git tag v1.0.0
#
# Recommended branching strategy:
#   main       — stable, tested code
#   develop    — integration branch
#   feature/*  — individual features (e.g., feature/csv-export)
#   bugfix/*   — bug fixes
# ============================================================================

# --- Compiled Java class files ---
*.class
*.jar
*.war
*.ear

# --- Build output directories ---
/bin/
/build/
/out/
/target/

# --- IDE-specific files ---

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.classpath
.project
.settings/

# VS Code
.vscode/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# --- OS-specific files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Application-generated files ---
# Scan cache files (can be regenerated by re-scanning)
*.cache
scan_cache/

# --- Log files ---
*.log

# --- Temporary files ---
*.tmp
*.swp
*~
